        "font": {
          "name": "宋体",
          "size_pt": 9,
          "bold": false,
          "color": "#000000"
        }
      },
      "right": {
        "text": "{page_number}",
        "font": {
          "name": "宋体",
          "size_pt": 9,
          "bold": false,
          "color": "#000000"
        }
      }
    },
    
    "footer": {
      "name": "页脚",
      "description": "页脚内容（页码）",
      "alignment": "center"
    }
