  "content_rules": {
    "min_total_chars": 15000,
    "min_chapter_chars": 1500,
    "min_section_chars": 300,
    "min_chapters": 6,
    "max_chapters": 10,
    "min_images": 50,
    "figure_caption_format": "图{number} {description}",
    "require_first_chapter_intro": true
  },
  
  "writing_style": {
    "type": "user_guide",
    "description": "用户操作指南风格",
    "rules": [
      "面向用户操作：描述用户点击什么、看到什么",
      "语言简洁：不使用技术术语",
      "图文结合：每个操作后跟'如下图'",
      "图名独立：图名单独成段，14pt居中"
    ],
    "forbidden_patterns": [
      "支持xxx功能",
      "提供xxx能力",
      "实现xxx管理"
    ]
  },
  
  "emu_conversions": {
    "1pt": 12700,
    "1cm": 360000,
    "1inch": 914400,
    "indent_1_18cm": 424800,
    "16pt": 203200,
    "22pt": 279400,
    "14pt": 177800
  }
